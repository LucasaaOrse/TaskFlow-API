{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Node 22",
  "_version": "22.0.0",

 "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "./", // Altere de "app" para "./" para abranger a raiz
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "generated/**/*"], // Adicione a pasta gerada aqui
  "exclude": ["node_modules", "dist"],
  "typeRoots": ["./src/@types", "./node_modules/@types"]
  
}